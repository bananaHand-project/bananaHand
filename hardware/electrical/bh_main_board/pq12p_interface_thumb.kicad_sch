	(text_box "IPROPI Resistor Selection:\n\n- A_IPROPI ~= 1000uA/A \n- Stall current of PQ12P is 210mA.\n- Select resistor to measure 3.3V at 300mA.\n\nI_PROPI @ 300mA:\nI_PROPI = 0.3A * 1000uA/A = 0.0003A\n\nV_PROPI = 3.3V @ 300mA:\nV_PROPI = I_PROPI * R_PROPI\nR_PROPI = 3.3 / 0.0003 = 11000 Ohms"
		(exclude_from_sim no)
		(at 60.96 100.33 0)
		(size 42.545 27.94)
		(margins 0.9525 0.9525 0.9525 0.9525)
